# Public hostname served by Traefik for the frontend router.
APP_DOMAIN=app.syrhealth.com

# Stable compose project name for this standalone frontend stack.
COMPOSE_PROJECT_NAME=lmj-frontend

# External Docker network already used by Traefik on the VPS.
TRAEFIK_PUBLIC_NETWORK=lmj-health-api-proxy

# Existing Traefik TLS entrypoint on the VPS.
TRAEFIK_ENTRYPOINTS=websecure

# Frontend image naming for production builds.
FRONTEND_IMAGE_NAME=lmj-health-frontend
FRONTEND_IMAGE_TAG=prod
