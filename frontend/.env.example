# Optional origin prefix for API calls.
# Leave empty to use same-origin /api requests through the Vite dev proxy.
VITE_API_ORIGIN=

# UI-only demo mode should stay disabled for real environments.
VITE_UI_ONLY=false

# GET /api/admin/lookups — فئة صفحة «تخصصات الأطباء» في لوحة الإدارة.
# يجب أن تطابق فئة كتالوج التسجيل GET /api/meta/doctor-specializations (المرجع: DOCTOR_SPECIALIZATION).
# الافتراضي في الكود الآن DOCTOR_SPECIALIZATION؛ إذا كانت البيئة القديمة تستخدم MEDICAL_CONDITION أو SPECIALIZATION فعيّنها صراحةً.
# VITE_ADMIN_DOCTOR_LOOKUP_CATEGORY=DOCTOR_SPECIALIZATION
