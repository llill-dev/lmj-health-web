# Optional origin prefix for API calls.
# Leave empty to use same-origin /api requests through the Vite dev proxy.
VITE_API_ORIGIN=

# UI-only demo mode should stay disabled for real environments.
VITE_UI_ONLY=false

# GET /api/admin/lookups — فئة الكتالوج (API-3: BLOOD_TYPE | ALLERGY | MEDICAL_CONDITION).
# استخدم MEDICAL_CONDITION مع الخادم الحالي؛ SPECIALIZATION بعد إضافتها في الـ validator.
# VITE_ADMIN_DOCTOR_LOOKUP_CATEGORY=MEDICAL_CONDITION
